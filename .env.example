# Required: your AI provider key. Copy this file to .env and paste your key.
AI_API_KEY=

# Recommended: a GitHub token lifts the rate limit from 60/hr to 5000/hr.
# Create one at https://github.com/settings/tokens (no scopes needed for public data).
GITHUB_TOKEN=

# Optional overrides (sensible defaults baked in):
AI_MODEL=claude-haiku-4-5
MAX_REPOS=25
README_MAX_CHARS=12000
CONCURRENCY=6
